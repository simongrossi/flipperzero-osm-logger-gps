# application.fam — minimal, ufbt-compatible

App(
    appid="osm_logger",
    name="OSM Logger",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="osm_logger_app",
    requires=["gui", "storage", "notification"],
    stack_size=2048,
    sources=[
        "src/osm_logger.c",
        "src/app.c",
        "src/nmea.c",
        "src/quick_log.c",
        "src/storage.c",
    ],
)
